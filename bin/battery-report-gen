<script>
const D = __BATT_DATA_JSON__;

// ── Helpers ──────────────────────────────────────────────────────────────
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function fmtLabel(iso, hours){
  const d = new Date(iso);
  const hh = String(d.getHours()).padStart(2,'0');
  const mm = String(d.getMinutes()).padStart(2,'0');
  if(hours > 24){
    const mo = String(d.getMonth()+1).padStart(2,'0');
    const dd = String(d.getDate()).padStart(2,'0');
    return mo+'-'+dd+' '+hh+':'+mm;
  }
  return hh+':'+mm;
}

function filterHours(ts, vals, hours){
  if(!ts.length) return {ts:[], vals: Array.isArray(vals[0]) ? vals.map(()=>[]) : []};
  const cutoff = Date.now() - hours*3600000;
  let idx = ts.findIndex(s => new Date(s).getTime() >= cutoff);
  if(idx < 0) idx = ts.length;
  const isNested = Array.isArray(vals) && vals.length > 0 && Array.isArray(vals[0]);
  if(isNested) return {ts: ts.slice(idx), vals: vals.map(v => v.slice(idx))};
  return {ts: ts.slice(idx), vals: vals.slice(idx)};
}

