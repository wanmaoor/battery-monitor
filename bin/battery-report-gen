#!/usr/bin/env python3
"""Battery dashboard: parse powermetrics → write CSVs → generate ~/battery/index.html."""

import argparse
import csv
import io
import json
import re
import subprocess
import sys
from datetime import datetime, timedelta
from pathlib import Path


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def parse_args():
    p = argparse.ArgumentParser()
    p.add_argument('--update',      action='store_true', help='Parse powermetrics and update CSVs before generating HTML')
    p.add_argument('--pm-output',   help='Path to raw powermetrics output file (required with --update)')
    p.add_argument('--timestamp',   help='ISO timestamp for this sample (required with --update)')
    p.add_argument('--sys-csv',     default=str(Path.home() / '.local/state/battery-drain-monitor/drain_sys.csv'))
    p.add_argument('--procs-csv',   default=str(Path.home() / '.local/state/battery-drain-monitor/drain_procs.csv'))
    p.add_argument('--temp-log',    default=str(Path.home() / '.local/state/battery-temp-monitor/status.log'))
    p.add_argument('--output',      default=str(Path.home() / 'battery/index.html'))
    p.add_argument('--top-n',       type=int, default=20)
    return p.parse_args()


# ---------------------------------------------------------------------------
# Powermetrics parsing
# ---------------------------------------------------------------------------

def parse_powermetrics(text, top_n):
    """Return dict with cpu_mw, gpu_mw, ane_mw, processes list."""
    result = {'cpu_mw': 0.0, 'gpu_mw': 0.0, 'ane_mw': 0.0, 'processes': []}

    in_tasks = False
    task_header_seen = False
    cpu_power_seen = False
    total_cpu_ms = 0.0

    for line in text.splitlines():
        s = line.strip()

        # Section markers
        if '*** Running tasks' in line:
            in_tasks = True
            task_header_seen = False
            continue
        if line.startswith('****') and in_tasks:
            in_tasks = False

        # Power lines (appear in **** Processor usage **** section)
        m = re.match(r'^CPU Power:\s*([\d.]+)\s*mW', s)
        if m:
            result['cpu_mw'] = float(m.group(1))
            cpu_power_seen = True
            continue
        m = re.match(r'^GPU Power:\s*([\d.]+)\s*mW', s)
        if m and cpu_power_seen and result['gpu_mw'] == 0:
            result['gpu_mw'] = float(m.group(1))
            continue
        m = re.match(r'^ANE Power:\s*([\d.]+)\s*mW', s)
        if m:
            result['ane_mw'] = float(m.group(1))
            continue

        # Task lines
        if in_tasks:
            if 'Name' in line and 'ID' in line and 'CPU ms/s' in line:
                task_header_seen = True
                continue
            if task_header_seen and s:
                parts = re.split(r'  +', s)
                if len(parts) < 3:
                    continue
                try:
                    pid = int(parts[1].strip())
                    cpu_ms = float(re.sub(r'[^\d.]', '', parts[2].strip()) or '0')
                except ValueError:
                    continue
                if pid <= 0:
                    continue
                total_cpu_ms += cpu_ms
                result['processes'].append({
                    'pid': str(pid),
                    'process': parts[0].strip(),
                    'cpu_ms_s': cpu_ms,
                })

    # Compute per-process derived metrics
    for proc in result['processes']:
        proc['cpu_pct'] = round(proc['cpu_ms_s'] / total_cpu_ms * 100, 2) if total_cpu_ms > 0 else 0.0
        proc['cpu_mw_est'] = round(proc['cpu_pct'] / 100 * result['cpu_mw'], 1)

    result['processes'].sort(key=lambda p: p['cpu_ms_s'], reverse=True)
    for i, proc in enumerate(result['processes'][:top_n], 1):
        proc['rank'] = i
    result['processes'] = result['processes'][:top_n]

    return result


# ---------------------------------------------------------------------------
# ioreg: battery info
# ---------------------------------------------------------------------------

def read_battery_ioreg():
    try:
        out = subprocess.check_output(
            ['/usr/sbin/ioreg', '-rn', 'AppleSmartBattery'],
            text=True, stderr=subprocess.DEVNULL,
        )
    except Exception:
        return {}

    fields = {}
    for key, pat in [
        ('CycleCount',        r'"CycleCount" = (\d+)'),
        ('MaxCapacity',       r'"MaxCapacity" = (\d+)'),
        ('DesignCapacity',    r'"DesignCapacity" = (\d+)'),
        ('CurrentCapacity',   r'"CurrentCapacity" = (\d+)'),
        ('Amperage',          r'"Amperage" = (-?\d+)'),
        ('Voltage',           r'"Voltage" = (\d+)'),
        ('ExternalConnected', r'"ExternalConnected" = (\w+)'),
        ('IsCharging',        r'"IsCharging" = (\w+)'),
    ]:
        m = re.search(pat, out)
        if m:
            v = m.group(1)
            if v in ('Yes', 'No'):
                fields[key] = (v == 'Yes')
            else:
                fields[key] = int(v)
    return fields


def compute_total_mw(ioreg):
    """Return total battery drain in mW (0 if charging or no data)."""
    amp = ioreg.get('Amperage', 0)
    volt = ioreg.get('Voltage', 0)
    if amp >= 0 or volt <= 0:
        return 0.0
    # amp is negative when discharging (mA), volt is mV → µW → mW
    return round(abs(amp) * volt / 1000.0, 1)


def compute_health(ioreg):
    max_cap = ioreg.get('MaxCapacity', 0)
    design_cap = ioreg.get('DesignCapacity', 0)
    if max_cap <= 0:
        return '—'
    if max_cap <= 100:
        return max_cap
    if design_cap > 0:
        return round(max_cap / design_cap * 100, 1)
    return '—'


# ---------------------------------------------------------------------------
# CSV I/O
# ---------------------------------------------------------------------------

SYS_FIELDS  = ['timestamp', 'battery_pct', 'cpu_mw', 'gpu_mw', 'ane_mw', 'total_mw', 'other_mw']
PROC_FIELDS = ['timestamp', 'rank', 'pid', 'process', 'cpu_ms_s', 'cpu_pct', 'cpu_mw_est']


def append_sys_csv(path, row):
    p = Path(path)
    write_header = not p.exists()
    with open(p, 'a', newline='', encoding='utf-8') as f:
        w = csv.DictWriter(f, fieldnames=SYS_FIELDS)
        if write_header:
            w.writeheader()
        w.writerow(row)


def append_procs_csv(path, rows):
    p = Path(path)
    write_header = not p.exists()
    with open(p, 'a', newline='', encoding='utf-8') as f:
        w = csv.DictWriter(f, fieldnames=PROC_FIELDS)
        if write_header:
            w.writeheader()
        w.writerows(rows)


def read_sys_csv(path, cutoff):
    p = Path(path)
    if not p.exists():
        return []
    rows = []
    try:
        with open(p, newline='', encoding='utf-8') as f:
            for row in csv.DictReader(f):
                try:
                    ts = datetime.fromisoformat(row['timestamp'])
                    if ts < cutoff:
                        continue
                    rows.append({
                        '_ts': ts,
                        'timestamp': row['timestamp'],
                        'battery_pct': int(row.get('battery_pct') or 0),
                        'cpu_mw':   float(row.get('cpu_mw')   or 0),
                        'gpu_mw':   float(row.get('gpu_mw')   or 0),
                        'ane_mw':   float(row.get('ane_mw')   or 0),
                        'total_mw': float(row.get('total_mw') or 0),
                        'other_mw': float(row.get('other_mw') or 0),
                    })
                except (ValueError, KeyError):
                    continue
    except OSError:
        pass
    return rows


def read_procs_csv(path, cutoff, top_n):
    p = Path(path)
    if not p.exists():
        return {}, []
    by_ts = {}
    all_rows = []
    latest_ts = None
    try:
        with open(p, newline='', encoding='utf-8') as f:
            for row in csv.DictReader(f):
                try:
                    ts = datetime.fromisoformat(row['timestamp'])
                    if ts < cutoff:
                        continue
                    r = {
                        '_ts': ts,
                        'timestamp': row['timestamp'],
                        'rank': int(row.get('rank') or 0),
                        'pid': row.get('pid', ''),
                        'process': row.get('process', ''),
                        'cpu_ms_s':  float(row.get('cpu_ms_s')  or 0),
                        'cpu_pct':   float(row.get('cpu_pct')   or 0),
                        'cpu_mw_est': float(row.get('cpu_mw_est') or 0),
                    }
                    all_rows.append(r)
                    ts_str = row['timestamp']
                    by_ts.setdefault(ts_str, []).append(r)
                    if latest_ts is None or ts > latest_ts:
                        latest_ts = ts
                except (ValueError, KeyError):
                    continue
    except OSError:
        pass

    # Latest snapshot (top 10 for the table)
    latest_snap = []
    if latest_ts is not None:
        latest_ts_str = latest_ts.strftime('%Y-%m-%dT%H:%M:%S')
        latest_snap = sorted(by_ts.get(latest_ts_str, []), key=lambda r: r['rank'])[:10]

    # Top 5 processes by cumulative cpu_pct for time-series chart
    pct_sum = {}
    for r in all_rows:
        pct_sum[r['process']] = pct_sum.get(r['process'], 0) + r['cpu_pct']
    top5 = sorted(pct_sum, key=lambda k: pct_sum[k], reverse=True)[:5]

    # Build time series per process
    timestamps = sorted(by_ts.keys())
    series = {}
    for name in top5:
        series[name] = []
        for ts_str in timestamps:
            match = next((r for r in by_ts[ts_str] if r['process'] == name), None)
            series[name].append(match['cpu_pct'] if match else None)

    return {
        'timestamps': timestamps,
        'top5': top5,
        'series': series,
        'latest_snap': latest_snap,
    }, all_rows


# ---------------------------------------------------------------------------
# Temperature log
# ---------------------------------------------------------------------------

def read_temp_log(path, cutoff):
    p = Path(path)
    if not p.exists():
        return []
    pattern = re.compile(r'^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) temp_c=([\d.]+)')
    buckets = {}
    try:
        with open(p, encoding='utf-8') as f:
            for line in f:
                m = pattern.match(line.strip())
                if not m:
                    continue
                try:
                    ts = datetime.strptime(m.group(1), '%Y-%m-%d %H:%M:%S')
                    if ts < cutoff:
                        continue
                    b = ts.replace(minute=(ts.minute // 5) * 5, second=0, microsecond=0)
                    buckets[b] = float(m.group(2))
                except ValueError:
                    continue
    except OSError:
        pass
    return [{'ts': ts.strftime('%Y-%m-%dT%H:%M:%S'), 'temp': buckets[ts]}
            for ts in sorted(buckets)]


def read_temp_thresholds():
    warn, critical = 40, 45
    cfg = Path.home() / '.config/battery-temp-monitor/config'
    if cfg.exists():
        text = cfg.read_text()
        m = re.search(r'BATTERY_TEMP_MONITOR_WARN_TEMP_C=(\d+)', text)
        if m:
            warn = int(m.group(1))
        m = re.search(r'BATTERY_TEMP_MONITOR_CRITICAL_TEMP_C=(\d+)', text)
        if m:
            critical = int(m.group(1))
    return warn, critical


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    args = parse_args()
    now = datetime.now()
    cutoff_7d = now - timedelta(days=7)

    # --- Step 1: parse powermetrics + update CSVs (--update mode) ---
    pm_data = None
    battery_pct = 0
    if args.update:
        if not args.pm_output or not args.timestamp:
            print('--update requires --pm-output and --timestamp', file=sys.stderr)
            sys.exit(1)

        pm_text = Path(args.pm_output).read_text(errors='replace')
        pm_data = parse_powermetrics(pm_text, args.top_n)

        ioreg = read_battery_ioreg()
        battery_pct = ioreg.get('CurrentCapacity', 0)
        total_mw = compute_total_mw(ioreg)
        subtotal = pm_data['cpu_mw'] + pm_data['gpu_mw'] + pm_data['ane_mw']
        other_mw = max(0.0, round(total_mw - subtotal, 1)) if total_mw > 0 else 0.0

        sys_row = {
            'timestamp':   args.timestamp,
            'battery_pct': battery_pct,
            'cpu_mw':      pm_data['cpu_mw'],
            'gpu_mw':      pm_data['gpu_mw'],
            'ane_mw':      pm_data['ane_mw'],
            'total_mw':    total_mw,
            'other_mw':    other_mw,
        }
        append_sys_csv(args.sys_csv, sys_row)

        proc_rows = [{
            'timestamp':   args.timestamp,
            'rank':        proc['rank'],
            'pid':         proc['pid'],
            'process':     proc['process'],
            'cpu_ms_s':    proc['cpu_ms_s'],
            'cpu_pct':     proc['cpu_pct'],
            'cpu_mw_est':  proc['cpu_mw_est'],
        } for proc in pm_data['processes']]
        append_procs_csv(args.procs_csv, proc_rows)

    # --- Step 2: read historical data ---
    ioreg = read_battery_ioreg()
    sys_rows = read_sys_csv(args.sys_csv, cutoff_7d)
    proc_data, _ = read_procs_csv(args.procs_csv, cutoff_7d, args.top_n)
    temp_data = read_temp_log(args.temp_log, cutoff_7d)
    warn_temp, critical_temp = read_temp_thresholds()

    # Current power state (most recent sys row)
    latest_sys = sys_rows[-1] if sys_rows else {}
    current_pct = ioreg.get('CurrentCapacity', latest_sys.get('battery_pct', '—'))
    is_charging = ioreg.get('IsCharging', False)
    external    = ioreg.get('ExternalConnected', False)
    if is_charging:
        status_text, status_class = 'Charging', 'charging'
    elif external:
        status_text, status_class = 'AC (Full)', 'full'
    else:
        status_text, status_class = 'Discharging', 'discharging'

    health = compute_health(ioreg)
    cycle_count = ioreg.get('CycleCount', '—')

    cur_temp = temp_data[-1]['temp'] if temp_data else None

    # Current power breakdown
    cur_cpu_mw   = latest_sys.get('cpu_mw', 0)
    cur_gpu_mw   = latest_sys.get('gpu_mw', 0)
    cur_ane_mw   = latest_sys.get('ane_mw', 0)
    cur_total_mw = latest_sys.get('total_mw', 0)
    cur_other_mw = latest_sys.get('other_mw', 0)

    # Time-series arrays for charts (sys level)
    sys_ts       = [r['timestamp'] for r in sys_rows]
    sys_cpu_mw   = [r['cpu_mw']   for r in sys_rows]
    sys_gpu_mw   = [r['gpu_mw']   for r in sys_rows]
    sys_ane_mw   = [r['ane_mw']   for r in sys_rows]
    sys_other_mw = [r['other_mw'] if r['other_mw'] > 0 else None for r in sys_rows]
    sys_batt_pct = [r['battery_pct'] for r in sys_rows]

    data = {
        # Meta
        'generatedAt': now.strftime('%Y-%m-%d %H:%M:%S'),
        'status':      status_text,
        'statusClass': status_class,
        # Cards
        'currentPct':  current_pct,
        'cycleCount':  cycle_count,
        'healthPct':   health,
        'curTempC':    round(cur_temp, 1) if cur_temp is not None else None,
        # Current power breakdown
        'curCpuMw':   cur_cpu_mw,
        'curGpuMw':   cur_gpu_mw,
        'curAneMw':   cur_ane_mw,
        'curTotalMw': cur_total_mw,
        'curOtherMw': cur_other_mw,
        'isCharging': is_charging or external,
        # System time-series
        'sysTsTmz':     sys_ts,
        'sysCpuMw':     sys_cpu_mw,
        'sysGpuMw':     sys_gpu_mw,
        'sysAneMw':     sys_ane_mw,
        'sysOtherMw':   sys_other_mw,
        'sysBattPct':   sys_batt_pct,
        # Process time-series
        'procTs':    proc_data.get('timestamps', []),
        'procTop5':  proc_data.get('top5', []),
        'procSeries': proc_data.get('series', {}),
        'procSnap':  [
            {
                'rank':      r['rank'],
                'process':   r['process'],
                'cpuPct':    r['cpu_pct'],
                'cpuMwEst':  r['cpu_mw_est'],
                'cpuMsS':    r['cpu_ms_s'],
                'pid':       r['pid'],
            }
            for r in proc_data.get('latest_snap', [])
        ],
        # Temperature
        'tempTs':       [t['ts']   for t in temp_data],
        'tempValues':   [t['temp'] for t in temp_data],
        'warnTemp':     warn_temp,
        'criticalTemp': critical_temp,
        # Chart colors
        'sysColors':  ['#3b82f6', '#8b5cf6', '#f59e0b', '#94a3b8'],
        'procColors': ['#3b82f6', '#f59e0b', '#10b981', '#ef4444', '#8b5cf6'],
    }

    html = HTML_TEMPLATE.replace('__BATT_DATA_JSON__', json.dumps(data, ensure_ascii=False))
    out = Path(args.output)
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(html, encoding='utf-8')
    print(f'Report written: {out}', file=sys.stderr)


