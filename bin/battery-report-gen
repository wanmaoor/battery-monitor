const TICK = {size:11,family:'-apple-system,sans-serif'};
const GRID = '#f0f0f0';

function baseOpts(yTitle, extra){
  return Object.assign({
    responsive:true, maintainAspectRatio:false,
    interaction:{mode:'index',intersect:false},
    plugins:{
      legend:{position:'top',labels:{font:TICK,boxWidth:12,padding:10}},
    },
    scales:{
      x:{ticks:{font:TICK,maxTicksLimit:10,autoSkip:true},grid:{color:GRID}},
      y:{ticks:{font:TICK},grid:{color:GRID},beginAtZero:true,
         title:{display:true,text:yTitle,font:TICK}},
    },
  }, extra||{});
}

