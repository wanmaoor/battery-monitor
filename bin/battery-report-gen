// ── Power breakdown panel ─────────────────────────────────────────────────
(function(){
  const rows = [
    {name:'CPU', mw: D.curCpuMw,   color:'#3b82f6'},
    {name:'GPU', mw: D.curGpuMw,   color:'#8b5cf6'},
    {name:'ANE', mw: D.curAneMw,   color:'#f59e0b'},
  ];
  if(!D.isCharging && D.curOtherMw > 0){
    rows.push({name:'Other', mw: D.curOtherMw, color:'#94a3b8'});
  }
  const ref = D.isCharging
    ? rows.reduce((s,r) => s+r.mw, 0)
    : (D.curTotalMw > 0 ? D.curTotalMw : rows.reduce((s,r) => s+r.mw, 0));

  const html = rows.map(r => {
    const pct = ref > 0 ? Math.min(100,(r.mw/ref*100)).toFixed(1) : '0';
    return `<div class="power-row">
      <div class="power-name">${esc(r.name)}</div>
      <div class="power-bar-wrap"><div class="power-bar" style="width:${pct}%;background:${r.color}"></div></div>
      <div class="power-mw">${r.mw.toFixed(0)} mW</div>
      <div class="power-pct">${pct}%</div>
    </div>`;
  }).join('');

  document.getElementById('power-rows').innerHTML = html;

  if(D.isCharging){
    document.getElementById('power-note').textContent =
      'Charging — total system drain from battery not available. Showing CPU+GPU+ANE only.';
  } else if(D.curTotalMw > 0){
    document.getElementById('power-note').textContent =
      'Other includes display backlight, keyboard, network, Bluetooth, and storage.';
    document.getElementById('power-total').style.display = 'flex';
    document.getElementById('power-total-val').textContent = D.curTotalMw.toFixed(0)+' mW';
  } else {
    document.getElementById('power-note').textContent =
      'Total battery drain unavailable (no discharge data yet).';
  }
})();

// ── Snapshot table ────────────────────────────────────────────────────────
const maxPct = Math.max(...D.procSnap.map(r => r.cpuPct), 0.01);
