// ── Range toggle ──────────────────────────────────────────────────────────
function setRange(range){
  document.getElementById('btn-24h').classList.toggle('active',range==='24h');
  document.getElementById('btn-7d').classList.toggle('active',range==='7d');
  const hours = range==='24h' ? 24 : 168;

  // System power
  const fs = filterHours(D.sysTsTmz,
    [D.sysCpuMw,D.sysGpuMw,D.sysAneMw,D.sysOtherMw], hours);
  chartSys.data.labels = fs.ts.map(s=>fmtLabel(s,hours));
  chartSys.data.datasets.forEach((ds,i)=>{ ds.data=fs.vals[i]; });
  chartSys.update();

  // Processes
  const fp = filterHours(D.procTs,
    D.procTop5.map(n=>D.procSeries[n]||[]), hours);
  chartProc.data.labels = fp.ts.map(s=>fmtLabel(s,hours));
  chartProc.data.datasets.forEach((ds,i)=>{ ds.data=fp.vals[i]; });
  chartProc.update();

  // Temperature
  const ft = filterHours(D.tempTs, D.tempValues, hours);
  chartTemp.data.labels = ft.ts.map(s=>fmtLabel(s,hours));
  chartTemp.data.datasets[0].data = ft.vals;
  chartTemp.data.datasets[1].data = ft.ts.map(()=>D.warnTemp);
  chartTemp.data.datasets[2].data = ft.ts.map(()=>D.criticalTemp);
  chartTemp.update();

  // Battery level
  const fb = filterHours(D.sysTsTmz, D.sysBattPct, hours);
  chartBatt.data.labels = fb.ts.map(s=>fmtLabel(s,hours));
  chartBatt.data.datasets[0].data = fb.vals;
  chartBatt.update();
}
