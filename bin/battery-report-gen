    <td class="tn tr">${r.cpuMwEst > 0 ? r.cpuMwEst.toFixed(0)+' mW' : '—'}</td>
    <td class="tn tr">${r.cpuMsS.toFixed(1)}</td>
    <td class="mini-bar"><div class="bar"><div class="bar-fill" style="width:${barW}%"></div></div></td>
    <td class="tn tm">${esc(r.pid)}</td>
  </tr>`;
}).join('');

